{
  "name": "@sai/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "dev:worker": "RUN_SCHEDULED_REPORTS=true ts-node src/worker.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:worker": "RUN_SCHEDULED_REPORTS=true node dist/worker.js",
    "test": "jest",
    "test:security": "jest src/__tests__/csrf.middleware.test.ts src/__tests__/csrf.integration.test.ts --coverage --collectCoverageFrom=src/middleware/csrf.ts --coverageReporters=json-summary --coverageReporters=text-summary && node ../../scripts/check-security-coverage.cjs coverage/coverage-summary.json src/middleware/csrf.ts 90 84 100 90",
    "test:watch": "jest --watch",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "check:node": "node ../../scripts/check-node-version.cjs",
    "predev": "npm run check:node",
    "prebuild": "npm run check:node",
    "pretest": "npm run check:node"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-sesv2": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@prisma/client": "^5.22.0",
    "@sai/risk-scoring": "*",
    "@sendgrid/mail": "^8.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.1",
    "chart.js": "^4.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "openid-client": "^6.8.2",
    "otplib": "^13.1.0",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.35.0",
    "redis": "^5.10.0",
    "uuid": "^11.1.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
