generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String
  password         String
  role             UserRole         @default(OPERATOR)
  mfaEnabled       Boolean          @default(false)
  mfaSecret        String?
  mfaRecoveryCodes String[]         @default([])
  companyId        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  AITool           AITool[]
  auditLogs        AuditLog[]       @relation("AuditActor")
  approvedControls Control[]        @relation("ControlApprover")
  ownedControls    Control[]        @relation("ControlOwner")
  reviewedControls Control[]        @relation("ControlReviewer")
  decisionLogs     DecisionLog[]    @relation("DecisionApprover")
  incidents        Incident[]       @relation("IncidentOwner")
  IncidentReview   IncidentReview[]
  approvedPolicies Policy[]         @relation("PolicyApprover")
  ownedPolicies    Policy[]         @relation("PolicyOwner")
  reviewedPolicies Policy[]         @relation("PolicyReviewer")
  refreshTokens    RefreshToken[]
  ownedRisks       Risk[]           @relation("RiskOwner")
  comments         Comment[]        @relation("CommentAuthor")
  company          Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([companyId])
}

model Company {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  industry            String?
  country             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aiTools             AITool[]
  mlIntegrations      MLIntegration[]
  auditLogs           AuditLog[]
  complianceSnapshots ComplianceSnapshot[]
  controls            Control[]
  DecisionLog         DecisionLog[]
  evidence            Evidence[]
  exceptions          Exception[]
  incidents           Incident[]
  IncidentReview      IncidentReview[]
  MetricAggregation   MetricAggregation[]
  PerformanceMetric   PerformanceMetric[]
  policies            Policy[]
  procedures          Procedure[]
  regulations         Regulation[]
  risks               Risk[]
  SLAAlert            SLAAlert[]
  users               User[]
  vendors             Vendor[]
  comments            Comment[]
  webhooks            Webhook[]

  @@index([email])
}

model AITool {
  id            String       @id @default(cuid())
  companyId     String
  name          String
  category      String
  vendor        String?
  description   String?
  url           String?
  dataTypes     String[]
  users         Int
  frequency     String
  controls      String[]
  riskScore     Int
  riskLevel     String
  hasDPA        Boolean      @default(false)
  dataResidency String?
  notes         String?
  customFields  Json?        // Custom fields (key-value pairs)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?    // Soft delete
  ownerId       String?
  status        AIToolStatus @default(ACTIVE)
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User          User?        @relation(fields: [ownerId], references: [id])
  exceptions    Exception[]
  riskScores    RiskScore[]

  @@index([companyId])
  @@index([riskLevel])
  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
}

model MLIntegration {
  id            String                 @id @default(cuid())
  companyId     String
  provider      MLIntegrationProvider
  displayName   String
  status        MLIntegrationStatus    @default(ACTIVE)
  config        Json?
  lastSyncedAt  DateTime?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([provider])
  @@index([status])
  @@index([deletedAt])
}

model RiskScore {
  id              String   @id @default(cuid())
  companyId       String
  toolId          String
  score           Int
  level           String
  factors         Json
  recommendations String[]
  createdAt       DateTime @default(now())
  tool            AITool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([toolId])
  @@index([createdAt])
}

model Policy {
  id          String          @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      LifecycleStatus @default(DRAFT)
  ownerId     String?
  approverId  String?
  reviewerId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  controls    Control[]
  approver    User?           @relation("PolicyApprover", fields: [approverId], references: [id])
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner       User?           @relation("PolicyOwner", fields: [ownerId], references: [id])
  reviewer    User?           @relation("PolicyReviewer", fields: [reviewerId], references: [id])

  @@index([companyId])
  @@index([status])
}

model Control {
  id              String              @id @default(cuid())
  companyId       String
  policyId        String?
  name            String
  description     String?
  status          LifecycleStatus     @default(DRAFT)
  ownerId         String?
  approverId      String?
  reviewerId      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  approver        User?               @relation("ControlApprover", fields: [approverId], references: [id])
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner           User?               @relation("ControlOwner", fields: [ownerId], references: [id])
  policy          Policy?             @relation(fields: [policyId], references: [id])
  reviewer        User?               @relation("ControlReviewer", fields: [reviewerId], references: [id])
  regulations     ControlRegulation[]
  evidence        Evidence[]
  IncidentControl IncidentControl[]
  procedures      Procedure[]
  risks           RiskControl[]

  @@index([companyId])
  @@index([status])
}

model Procedure {
  id        String   @id @default(cuid())
  companyId String
  controlId String
  name      String
  steps     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([controlId])
}

model Regulation {
  id          String              @id @default(cuid())
  companyId   String
  framework   String
  article     String?
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  controls    ControlRegulation[]
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([framework])
}

model ControlRegulation {
  id           String     @id @default(cuid())
  controlId    String
  regulationId String
  control      Control    @relation(fields: [controlId], references: [id], onDelete: Cascade)
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@unique([controlId, regulationId])
  @@index([controlId])
  @@index([regulationId])
}

model Risk {
  id          String        @id @default(cuid())
  companyId   String
  title       String
  description String?
  likelihood  Int
  impact      Int
  ownerId     String?
  customFields Json?        // Custom fields (key-value pairs)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?     // Soft delete
  category    String
  decisions   DecisionLog[]
  Exception   Exception[]
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner       User?         @relation("RiskOwner", fields: [ownerId], references: [id])
  controls    RiskControl[]

  @@index([companyId])
  @@index([category])
  @@index([deletedAt])
}

model RiskControl {
  id        String  @id @default(cuid())
  riskId    String
  controlId String
  control   Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  risk      Risk    @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([riskId, controlId])
  @@index([riskId])
  @@index([controlId])
}

model DecisionLog {
  id         String           @id @default(cuid())
  companyId  String
  riskId     String?
  decision   RiskDecisionType
  rationale  String?
  approvedBy String?
  immutable  Boolean          @default(false)
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime
  approver   User?            @relation("DecisionApprover", fields: [approvedBy], references: [id])
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  risk       Risk?            @relation(fields: [riskId], references: [id])

  @@index([companyId])
  @@index([riskId])
  @@index([immutable])
}

model Evidence {
  id          String         @id @default(cuid())
  companyId   String
  controlId   String
  source      String
  status      EvidenceStatus @default(MISSING)
  validFrom   DateTime?
  validTo     DateTime?
  reference   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  contentHash String?
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control     Control        @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([controlId])
  @@index([status])
}

model Incident {
  id                String            @id @default(cuid())
  companyId         String
  title             String
  description       String?
  severity          String
  status            IncidentStatus    @default(DETECTED)
  detectedAt        DateTime          @default(now())
  resolvedAt        DateTime?
  reportedAt        DateTime?
  reportingDeadline DateTime?
  ownerId           String?
  customFields      Json?            // Custom fields (key-value pairs)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?        // Soft delete
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner             User?             @relation("IncidentOwner", fields: [ownerId], references: [id])
  IncidentControl   IncidentControl[]
  IncidentReview    IncidentReview[]

  @@index([companyId])
  @@index([status])
  @@index([reportingDeadline])
  @@index([deletedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String?
  action     String
  targetType String
  targetId   String?
  changes    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([action])
  @@index([createdAt])
}

model ComplianceSnapshot {
  id        String   @id @default(cuid())
  companyId String
  summary   Json
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
}

model Exception {
  id          String    @id @default(cuid())
  companyId   String
  toolId      String?
  riskId      String?
  requestedBy String?
  approvedBy  String?
  status      String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  risk        Risk?     @relation(fields: [riskId], references: [id])
  tool        AITool?   @relation(fields: [toolId], references: [id])

  @@index([companyId])
  @@index([toolId])
  @@index([riskId])
}

model Vendor {
  id                   String   @id @default(cuid())
  companyId            String
  name                 String
  region               String?
  subprocessors        Json?
  securityReviewStatus String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([name])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model IncidentControl {
  id         String   @id
  incidentId String
  controlId  String
  createdAt  DateTime @default(now())
  Control    Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  Incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([incidentId, controlId])
  @@index([controlId])
  @@index([incidentId])
}

model IncidentReview {
  id                  String    @id
  companyId           String
  incidentId          String
  rootCause           String?
  lessonsLearned      String?
  followUpActions     String[]
  reviewedBy          String?
  reviewedAt          DateTime?
  requiredEvidenceIds String[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
  Company             Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Incident            Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  User                User?     @relation(fields: [reviewedBy], references: [id])

  @@index([companyId])
  @@index([incidentId])
}

model MetricAggregation {
  id           String   @id
  companyId    String?
  endpoint     String
  period       String
  periodStart  DateTime
  periodEnd    DateTime
  count        Int
  avgDuration  Float
  p50          Int
  p95          Int
  p99          Int
  minDuration  Int
  maxDuration  Int
  errorCount   Int
  errorRate    Float
  slaCompliant Boolean
  createdAt    DateTime @default(now())
  Company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, endpoint, period, periodStart])
  @@index([companyId])
  @@index([endpoint])
  @@index([periodStart])
  @@index([period])
}

model PerformanceMetric {
  id         String   @id
  companyId  String?
  endpoint   String
  method     String
  path       String
  statusCode Int
  duration   Int
  timestamp  DateTime @default(now())
  Company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([endpoint])
  @@index([endpoint, timestamp])
  @@index([statusCode])
  @@index([timestamp])
}

model SLAAlert {
  id            String    @id
  companyId     String
  endpoint      String
  violationType String
  threshold     Float
  actualValue   Float
  message       String
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  Company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([resolved])
}

enum UserRole {
  MANAGEMENT
  ADMIN
  AUDITOR
  OPERATOR
}

enum LifecycleStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  RETIRED
}

enum EvidenceStatus {
  MISSING
  SUBMITTED
  APPROVED
  EXPIRED
}

enum IncidentStatus {
  DETECTED
  CLASSIFIED
  ESCALATED
  RESOLVED
  REVIEWED
}

enum MLIntegrationProvider {
  MLFLOW
  SAGEMAKER
  VERTEX_AI
  OTHER
}

enum MLIntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum RiskDecisionType {
  ACCEPTED
  DEFERRED
  REJECTED
}

enum AIToolStatus {
  ACTIVE
  DEPRECATED
  RETIRED
}

model Comment {
  id        String   @id @default(cuid())
  companyId String
  targetType String // TOOL, RISK, INCIDENT
  targetId   String
  content   String
  authorId  String
  parentId  String? // For threaded comments
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([targetType, targetId])
  @@index([parentId])
}

model Webhook {
  id        String   @id @default(cuid())
  companyId String
  url       String
  events    String[] // Array of event types
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([active])
}
