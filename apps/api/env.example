# Backend Database (local Docker default)
# Local format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://sai_user:sai_password@localhost:5432/sai_db

# Optional Neon format (production/staging):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# JWT Configuration
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_DAYS=30

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# MFA / Security
MFA_ISSUER=SAI Platform

# Email (notifications, alerts)
#   console — print to stdout (default in development when unset)
#   log     — structured logger only
#   none    — drop silently (default in production when unset; logs one production warning)
#   smtp      — send via SMTP when SMTP_HOST, SMTP_USER, SMTP_PASS are set (optional: SMTP_PORT, SMTP_FROM, SMTP_SECURE=true)
#   sendgrid  — SENDGRID_API_KEY + SENDGRID_FROM (verified sender in SendGrid)
#   ses       — SES_FROM + AWS_REGION; credentials via AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY or instance role
# EMAIL_PROVIDER=console
#
# SMTP (only when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="SAI Platform <your-email@gmail.com>"
# SMTP_SECURE=false
#
# SendGrid (EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM=noreply@your-verified-domain.com
#
# Amazon SES (EMAIL_PROVIDER=ses) — SES_FROM must be a verified identity in SES
# SES_FROM=noreply@your-verified-domain.com
# AWS_REGION=eu-west-1
# (Use IAM role in AWS, or set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY for local dev)

# Stripe (for future billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# File Storage (optional)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=eu-west-1
AWS_S3_BUCKET=sai-platform-files

# Monitoring & Logging (optional)
SENTRY_DSN=https://your-key@sentry.io/project-id

# SSO / OIDC (optional, for enterprise — enables GET /api/auth/oidc/login)
# Issuer must expose /.well-known/openid-configuration (Azure AD, Okta, Auth0, Keycloak, etc.)
OIDC_ISSUER=https://login.microsoftonline.com/your-tenant-id/v2.0
OIDC_CLIENT_ID=client-id
OIDC_CLIENT_SECRET=client-secret
# Must match the redirect URL registered at the IdP (API host + path)
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/oidc/callback
# First-time SSO users: create company + user automatically (off by default)
OIDC_JIT_PROVISIONING=false
# Optional: restrict logins to one email domain, e.g. @acme.com
# OIDC_ALLOWED_EMAIL_DOMAIN=@acme.com

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Evidentia evidence-service (optional — SAI governs Evidentia when set)
# Base URL of the running evidence-service (no trailing slash), e.g. local stack http://localhost:8080
EVIDENTIA_EVIDENCE_BASE_URL=http://localhost:8080
# Machine JWT accepted by Evidentia (must include tenant claim tid or tenant_id per Evidentia config)
EVIDENTIA_SERVICE_BEARER_TOKEN=
# When true, disables global bearer token fallback and requires per-company `CompanyEvidentiaLink` secret refs.
# EVIDENTIA_REQUIRE_COMPANY_LINK=true
# Resilience (optional — defaults are sane for dev)
# EVIDENTIA_HTTP_TIMEOUT_MS=10000
# EVIDENTIA_CIRCUIT_FAILURE_THRESHOLD=5
# EVIDENTIA_CIRCUIT_COOLDOWN_MS=30000
