# Backend Database (Neon example; keep sslmode=require)
# Format: postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
DATABASE_URL=postgresql://neon_user:neon_password@your-neon-host.neon.tech/sai_db?sslmode=require

# JWT Configuration
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_DAYS=30

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# MFA / Security
MFA_ISSUER=SAI Platform

# Email Service (optional, for notifications/reset in future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Stripe (for future billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# File Storage (optional)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=eu-west-1
AWS_S3_BUCKET=sai-platform-files

# Monitoring & Logging (optional)
SENTRY_DSN=https://your-key@sentry.io/project-id

# SSO / OIDC (optional, for enterprise)
OIDC_ISSUER=https://your-idp.com/
OIDC_CLIENT_ID=client-id
OIDC_CLIENT_SECRET=client-secret
OIDC_REDIRECT_URI=https://app.yourdomain.com/api/auth/oidc/callback

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379
