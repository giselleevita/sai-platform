# Prefer same-origin API calls in dev (Next rewrites proxy /api/* to the API server).
# Set this only for production deployments where the API is on a different origin.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# When the API has OIDC_* set, GET /api/health/oidc returns oidcEnabled:true and the login page shows “Sign in with SSO”.
