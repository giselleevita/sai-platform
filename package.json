{
  "name": "sai-platform",
  "version": "0.1.0",
  "description": "Secure AI Integration SaaS Platform",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@sai/api...",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check:node": "node scripts/check-node-version.cjs",
    "predev": "npm run check:node",
    "prebuild": "npm run check:node",
    "pretest": "npm run check:node && turbo run build --filter=@sai/risk-scoring --filter=@sai/shared-types",
    "setup": "bash scripts/setup.sh",
    "test:mvp": "bash tests/api/test-mvp-happy-path.sh",
    "test:csrf": "bash tests/api/test-csrf-auth.sh",
    "test:sprint": "bash tests/api/test-sprint-smoke.sh",
    "test:api-smoke": "npm run build:api && npm run test:sprint",
    "test:sprint:local": "bash scripts/sprint-smoke-local.sh"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=9"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "next": {
      "postcss": "^8.5.10"
    }
  }
}
